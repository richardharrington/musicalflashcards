{
  "expo": {
    "name": "Musical Flashcards",
    "slug": "musicalflashcards",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.richardharrington.musicalflashcards"
    },
    "android": {
      "package": "com.richardharrington.musicalflashcards",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": false,
          "iosMicrophonePermission": "Musical Flashcards uses the microphone to hear the notes you play and compare them to the displayed notes.",
          "androidPermissions": [
            "android.permission.RECORD_AUDIO"
          ],
          "androidForegroundService": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Musical Flashcards uses the microphone to hear the notes you play and compare them to the displayed notes."
        }
      ],
      "expo-asset"
    ]
  }
}
